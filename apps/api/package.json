{
  "name": "@rss-boi/api",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/prisma && cp -R ../../prisma/generated dist/prisma",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "node dist/apps/api/src/index.js",
    "typecheck": "tsc --noEmit",
    "users:create": "tsx src/cli/index.ts users:create",
    "users:disable": "tsx src/cli/index.ts users:disable",
    "users:reset-password": "tsx src/cli/index.ts users:reset-password"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/sensible": "^6.0.3",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@prisma/client-runtime-utils": "^7.7.0",
    "@rss-boi/shared": "workspace:*",
    "argon2": "^0.44.0",
    "fastify": "^5.6.1",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "rss-parser": "^3.13.0",
    "sanitize-html": "^2.17.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "tsx": "^4.20.6"
  }
}
